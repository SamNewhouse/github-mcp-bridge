# Default PAT — used for any owner that doesn't have a dedicated GITHUB_PAT_* entry
GITHUB_PAT=ghp_your_token_here

# Owner-specific PATs — optional, add as many as you need.
# The key suffix is the owner name uppercased with hyphens replaced by underscores.
# e.g. owner "SamNewhouse"  → GITHUB_PAT_SAMNEWHOUSE
#      owner "my-org"       → GITHUB_PAT_MY_ORG
#      owner "Dr-Dog-Games" → GITHUB_PAT_DR_DOG_GAMES
# GITHUB_PAT_SAMNEWHOUSE=ghp_personal_token_here
# GITHUB_PAT_MY_ORG=ghp_org_token_here
# GITHUB_PAT_ANOTHER_ORG=ghp_another_token_here

CONNECTOR_SECRET=your_shared_secret_here
PORT=3303
