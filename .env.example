# Default PAT — used for any owner that doesn't have a dedicated GITHUB_PAT_* entry
GITHUB_PAT=ghp_your_token_here

# Owner-specific PATs — optional, add as many as you need.
# The suffix must exactly match the GitHub username or organisation name.
# e.g. if owner is "my-org", set GITHUB_PAT_my-org
# GITHUB_PAT_SamNewhouse=ghp_personal_token_here
# GITHUB_PAT_my-org=ghp_org_token_here

CONNECTOR_SECRET=your_shared_secret_here
PORT=3303
