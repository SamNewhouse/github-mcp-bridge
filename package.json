{
  "name": "github-mcp-bridge",
  "version": "1.0.0",
  "description": "A TypeScript GitHub MCP bridge with an MCP agent client.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:server": "tsx watch src/server.ts",
    "dev:agent": "tsx src/agent/index.ts",
    "dev:agent:watch": "tsx watch src/agent/index.ts",
    "build": "tsc -p tsconfig.json",
    "format": "prettier --write .",
    "start": "tsx src/server.ts",
    "start:server": "tsx src/server.ts",
    "start:agent": "tsx src/agent/index.ts",
    "test": "tsc --noEmit"
  },
  "keywords": [
    "github",
    "mcp",
    "typescript",
    "bridge",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "private": false,
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=24"
  }
}
