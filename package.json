{
  "name": "github-mcp-bridge",
  "version": "1.0.0",
  "description": "A small TypeScript GitHub MCP bridge.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "format": "prettier --write .",
    "start": "node dist/server.js",
    "test": "tsc --noEmit"
  },
  "keywords": [
    "github",
    "mcp",
    "typescript",
    "bridge"
  ],
  "author": "",
  "license": "MIT",
  "private": false,
  "dependencies": {
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20"
  }
}
