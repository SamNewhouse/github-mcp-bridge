{
  "name": "github-mcp-bridge",
  "version": "1.0.0",
  "description": "A lightweight TypeScript MCP server that exposes GitHub operations as JSON-RPC tools over HTTP. Drop-in connector for any MCP-compatible AI client.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "format": "prettier --write .",
    "start": "node dist/server.js",
    "test": "jest",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "17.4.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "24.13.3",
    "jest": "29.7.0",
    "prettier": "3.9.6",
    "ts-jest": "29.4.0",
    "tsx": "4.23.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": "24.x"
  },
  "license": "MIT",
  "private": false,
  "author": {
    "name": "Sam Newhouse",
    "url": "https://github.com/SamNewhouse"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SamNewhouse/github-mcp-bridge.git"
  },
  "homepage": "https://github.com/SamNewhouse/github-mcp-bridge#readme",
  "bugs": {
    "url": "https://github.com/SamNewhouse/github-mcp-bridge/issues"
  },
  "keywords": [
    "github",
    "mcp",
    "model-context-protocol",
    "typescript",
    "bridge",
    "ai",
    "llm",
    "tool-use",
    "json-rpc",
    "github-api",
    "vercel",
    "serverless",
    "automation",
    "developer-tools"
  ]
}
